---
import ContactLink from "./ContactLink.astro";

interface Props {
  class?: string;
  "aria-label"?: string;
  title?: string;
}

const hasDefaultSlot = Astro.slots.has("default");
---

{
  hasDefaultSlot ? (
    <ContactLink
      type="email"
      class={Astro.props.class}
      aria-label={Astro.props["aria-label"]}
      title={Astro.props.title}
    >
      <slot />
    </ContactLink>
  ) : (
    <ContactLink
      type="email"
      class={Astro.props.class}
      aria-label={Astro.props["aria-label"]}
      title={Astro.props.title}
    />
  )
}
