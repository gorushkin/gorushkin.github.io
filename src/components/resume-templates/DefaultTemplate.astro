---
import EmailLink from "../EmailLink.astro";
import { getSplitAboutSections, info, resumeSections } from "../resumeData";

const { about, focus } = getSplitAboutSections(4);
---

<main
  class="bg-gray-100 px-4 py-8 text-black sm:px-6 print:bg-white print:px-0 print:py-0"
>
  <article
    class="mx-auto max-w-4xl bg-white p-8 shadow-lg print:max-w-none print:p-0 print:shadow-none"
  >
    <header
      class="mb-6 border-b border-gray-300 pb-4"
    >
      <div>
        <h1 class="text-4xl font-bold leading-tight">{info.name}</h1>
        <p class="mt-2 text-lg text-gray-600">{info.title}</p>
        <address
          class="mt-2 flex flex-wrap gap-x-2 gap-y-1 text-sm not-italic leading-6 text-gray-600"
        >
          <span>{info.location} • {info.workFormat}</span>
          <span aria-hidden="true">|</span>
          <EmailLink class="underline-offset-4 hover:underline" />
          <span aria-hidden="true">|</span>
          <a
            class="underline-offset-4 hover:underline"
            href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}
            >telegram</a
          >
          <span aria-hidden="true">|</span>
          <a class="underline-offset-4 hover:underline" href={info.contacts.github}
            >github</a
          >
        </address>
      </div>
    </header>

    <section class="mb-8">
      <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">
        {about.title}
      </h2>
      <div class="space-y-3 text-sm leading-6 text-gray-700">
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">
        {resumeSections.skills.title}
      </h2>
      <ul class="list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
        {
          resumeSections.skills.groups.map(([title, skills]) => (
            <li>
              <span class="font-semibold text-black">{title}:</span>{" "}
              {skills.join(", ")}
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">
        {resumeSections.experience.title}
      </h2>
      <div class="space-y-6">
        {
          resumeSections.experience.jobs.map((job) => (
            <section>
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <p class="text-lg font-bold">
                  {job.position} | {job.company}
                </p>
                <p class="text-sm text-gray-600">{job.period}</p>
              </div>
              <p class="mt-2 text-sm font-semibold leading-6 text-gray-700">
                {job.summary}
              </p>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
                {job.details.map((detail) => (
                  <li>{detail}</li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">
        {resumeSections.education.title}
      </h2>
      <div class="space-y-4 text-sm leading-6 text-gray-700">
        {resumeSections.education.items.map((item) => (
          <section>
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <p class="font-bold text-black">{item.institution}</p>
              <p class="text-gray-600">{item.period}</p>
            </div>
            <p>{item.degree}</p>
          </section>
        ))}
        <section>
          <p class="font-bold text-black">Курсы</p>
          <ul class="mt-1 list-disc space-y-1 pl-5">
            {resumeSections.education.courses.map((course) => (
              <li>
                {course.title}, {course.provider}, {course.period}
              </li>
            ))}
          </ul>
        </section>
      </div>
    </section>

    <section>
      <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">
        {focus.title}
      </h2>
      <ul class="list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
        {focus.paragraphs.map((paragraph) => <li>{paragraph}</li>)}
      </ul>
    </section>
  </article>
</main>
