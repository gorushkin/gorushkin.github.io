---
import { frontmatter as info } from "../data/info.md";
const { style } = Astro.props;

const skillGroups = [
  ["Основной стек", info.skills.main],
  ["Дополнительно", info.skills.additional],
  ["Архитектура", info.skills.architecture],
  ["Тестирование", info.skills.testing],
  ["Backend", info.skills.backend],
  ["UI", info.skills.ui],
  ["Стили", info.skills.styles],
  ["Интеграции", info.skills.integrations],
  ["Инфраструктура", info.skills.infrastructure],
  ["Инструменты", info.skills.tools],
];

const primarySkills = [
  ...info.skills.main,
  ...info.skills.additional,
  ...info.skills.architecture,
  ...info.skills.testing,
];
---

{style.id === "classic" && (
    <main class="mx-auto min-h-screen w-full max-w-6xl px-4 py-6 sm:px-6 lg:px-8 print:max-w-none print:px-0 print:py-0">
      <article class="overflow-hidden bg-white shadow-sm ring-1 ring-zinc-200 print:shadow-none print:ring-0">
        <header class="border-b border-zinc-200 bg-zinc-950 px-6 py-8 text-white sm:px-10 lg:px-12 print:bg-white print:px-0 print:py-0 print:text-zinc-950">
          <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300 print:text-zinc-600">
                {info.title}
              </p>
              <h1 class="mt-3 text-4xl font-bold leading-tight sm:text-5xl">
                {info.name}
              </h1>
              <p class="mt-4 max-w-3xl text-base leading-7 text-zinc-200 print:text-zinc-700">
                {info.description}
              </p>
            </div>

            <address class="not-italic text-sm leading-7 text-zinc-200 print:text-zinc-700">
              <div>{info.location} • {info.workFormat}</div>
              <a class="block underline-offset-4 hover:underline" href={`mailto:${info.contacts.email}`}>
                {info.contacts.email}
              </a>
              <a class="block underline-offset-4 hover:underline" href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}>
                Telegram: {info.contacts.telegram}
              </a>
              <a class="block underline-offset-4 hover:underline" href={info.contacts.github}>
                GitHub: {info.contacts.github.replace("https://", "")}
              </a>
            </address>
          </div>
        </header>

        <div class="grid gap-10 px-6 py-8 sm:px-10 lg:grid-cols-[280px_1fr] lg:px-12 lg:py-10 print:grid-cols-[240px_1fr] print:px-0 print:py-6">
          <aside class="space-y-8">
            <section>
              <h2 class="border-b border-zinc-300 pb-2 text-sm font-bold uppercase tracking-[0.16em] text-zinc-500">
                Технологии
              </h2>
              <div class="mt-5 space-y-5">
                {skillGroups.map(([title, skills]) => (
                  <div>
                    <h3 class="text-sm font-semibold text-zinc-950">{title}</h3>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {skills.map((skill) => (
                        <span class="rounded border border-zinc-300 bg-zinc-50 px-2.5 py-1 text-xs font-medium text-zinc-700 print:bg-white">
                          {skill}
                        </span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </section>
          </aside>

          <div class="space-y-10">
            <section>
              <h2 class="border-b border-zinc-300 pb-2 text-sm font-bold uppercase tracking-[0.16em] text-zinc-500">
                Обо мне
              </h2>
              <div class="mt-5 space-y-4 text-[15px] leading-7 text-zinc-700">
                {info.about.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </section>

            <section>
              <h2 class="border-b border-zinc-300 pb-2 text-sm font-bold uppercase tracking-[0.16em] text-zinc-500">
                Опыт работы
              </h2>
              <div class="mt-6 space-y-9">
                {info.experience.map((job) => (
                  <section class="grid gap-3 border-l-2 border-zinc-200 pl-5">
                    <div class="grid gap-1 sm:grid-cols-[1fr_auto] sm:items-start">
                      <div>
                        <h3 class="text-xl font-bold text-zinc-950">{job.company}</h3>
                        <p class="mt-1 text-sm font-semibold text-emerald-700">{job.position}</p>
                      </div>
                      <p class="text-sm font-medium text-zinc-500 sm:text-right">{job.period}</p>
                    </div>
                    <p class="text-[15px] font-medium leading-7 text-zinc-800">{job.summary}</p>
                    <ul class="space-y-2 text-[15px] leading-7 text-zinc-700">
                      {job.details.map((detail) => (
                        <li class="relative pl-5 before:absolute before:left-0 before:top-[0.72em] before:h-1.5 before:w-1.5 before:rounded-full before:bg-emerald-600">
                          {detail}
                        </li>
                      ))}
                    </ul>
                  </section>
                ))}
              </div>
            </section>
          </div>
        </div>
      </article>
    </main>
  )}

  {style.id === "compact" && (
    <main class="mx-auto min-h-screen w-full max-w-5xl bg-white px-5 py-6 sm:px-8 lg:px-10 print:max-w-none print:px-0 print:py-0">
      <header class="grid gap-5 border-b-4 border-sky-700 pb-5 md:grid-cols-[1fr_auto] md:items-end">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-sky-700">{info.title}</p>
          <h1 class="mt-2 text-4xl font-extrabold leading-tight text-zinc-950">{info.name}</h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-zinc-700">{info.description}</p>
        </div>
        <address class="not-italic text-sm leading-6 text-zinc-700 md:text-right">
          <div>{info.location} • {info.workFormat}</div>
          <a class="block text-sky-800 underline-offset-4 hover:underline" href={`mailto:${info.contacts.email}`}>{info.contacts.email}</a>
          <a class="block text-sky-800 underline-offset-4 hover:underline" href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}>{info.contacts.telegram}</a>
          <a class="block text-sky-800 underline-offset-4 hover:underline" href={info.contacts.github}>{info.contacts.github.replace("https://", "")}</a>
        </address>
      </header>

      <section class="border-b border-zinc-200 py-5">
        <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-zinc-500">Ключевые технологии</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {primarySkills.map((skill) => (
            <span class="rounded-sm bg-sky-50 px-2 py-1 text-xs font-semibold text-sky-900">{skill}</span>
          ))}
        </div>
      </section>

      <div class="grid gap-8 py-6 lg:grid-cols-[1fr_2fr]">
        <section>
          <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-zinc-500">Профиль</h2>
          <div class="mt-3 space-y-3 text-sm leading-6 text-zinc-700">
            {info.about.slice(0, 4).map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>

        <section>
          <h2 class="text-xs font-bold uppercase tracking-[0.16em] text-zinc-500">Опыт</h2>
          <div class="mt-4 space-y-6">
            {info.experience.map((job) => (
              <section class="border-t border-zinc-200 pt-4 first:border-t-0 first:pt-0">
                <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                  <h3 class="text-lg font-bold text-zinc-950">{job.company}</h3>
                  <p class="text-xs font-semibold uppercase tracking-[0.08em] text-zinc-500">{job.period}</p>
                </div>
                <p class="mt-1 text-sm font-semibold text-sky-800">{job.position}</p>
                <p class="mt-2 text-sm leading-6 text-zinc-800">{job.summary}</p>
                <ul class="mt-2 space-y-1.5 text-sm leading-6 text-zinc-700">
                  {job.details.slice(0, 4).map((detail) => (
                    <li class="pl-4 [text-indent:-1rem]">- {detail}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>
      </div>
    </main>
  )}

  {style.id === "editorial" && (
    <main class="min-h-screen bg-stone-50 px-4 py-6 text-zinc-950 sm:px-8 lg:px-12 print:bg-white print:px-0 print:py-0">
      <article class="mx-auto max-w-6xl">
        <header class="grid min-h-[48vh] content-end gap-8 border-b border-zinc-300 pb-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-rose-700">{info.title}</p>
            <h1 class="mt-5 max-w-4xl text-6xl font-black leading-none text-zinc-950 sm:text-7xl">
              {info.name}
            </h1>
          </div>
          <div class="space-y-5">
            <p class="text-xl leading-8 text-zinc-700">{info.description}</p>
            <address class="grid gap-1 not-italic text-sm font-medium text-zinc-700">
              <span>{info.location} • {info.workFormat}</span>
              <a class="text-rose-800 underline-offset-4 hover:underline" href={`mailto:${info.contacts.email}`}>{info.contacts.email}</a>
              <a class="text-rose-800 underline-offset-4 hover:underline" href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}>Telegram: {info.contacts.telegram}</a>
              <a class="text-rose-800 underline-offset-4 hover:underline" href={info.contacts.github}>GitHub: {info.contacts.github.replace("https://", "")}</a>
            </address>
          </div>
        </header>

        <section class="grid gap-8 border-b border-zinc-300 py-10 lg:grid-cols-[220px_1fr]">
          <h2 class="text-sm font-bold uppercase tracking-[0.18em] text-rose-700">Обо мне</h2>
          <div class="columns-1 gap-8 space-y-4 text-base leading-8 text-zinc-700 md:columns-2">
            {info.about.map((paragraph) => (
              <p class="break-inside-avoid">{paragraph}</p>
            ))}
          </div>
        </section>

        <section class="grid gap-8 border-b border-zinc-300 py-10 lg:grid-cols-[220px_1fr]">
          <h2 class="text-sm font-bold uppercase tracking-[0.18em] text-rose-700">Технологии</h2>
          <div class="grid gap-4 sm:grid-cols-2">
            {skillGroups.map(([title, skills]) => (
              <div class="border-t border-zinc-300 pt-3">
                <h3 class="text-sm font-bold text-zinc-950">{title}</h3>
                <p class="mt-2 text-sm leading-6 text-zinc-700">{skills.join(", ")}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="grid gap-8 py-10 lg:grid-cols-[220px_1fr]">
          <h2 class="text-sm font-bold uppercase tracking-[0.18em] text-rose-700">Опыт работы</h2>
          <div class="space-y-10">
            {info.experience.map((job) => (
              <section>
                <p class="text-sm font-bold uppercase tracking-[0.12em] text-zinc-500">{job.period}</p>
                <h3 class="mt-2 text-3xl font-black leading-tight text-zinc-950">{job.company}</h3>
                <p class="mt-1 text-base font-bold text-rose-800">{job.position}</p>
                <p class="mt-4 text-base font-medium leading-7 text-zinc-800">{job.summary}</p>
                <ul class="mt-4 grid gap-3 text-[15px] leading-7 text-zinc-700">
                  {job.details.map((detail) => (
                    <li class="border-l-2 border-rose-700 pl-4">{detail}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>
      </article>
    </main>
  )}

  {style.id === "default" && (
    <main class="bg-gray-100 px-4 py-8 text-black sm:px-6 print:bg-white print:px-0 print:py-0">
      <article class="mx-auto max-w-4xl bg-white p-8 shadow-lg print:max-w-none print:p-0 print:shadow-none">
        <header class="mb-6 flex flex-col gap-4 border-b border-gray-300 pb-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <h1 class="text-4xl font-bold leading-tight">{info.name}</h1>
            <p class="mt-2 text-lg text-gray-600">{info.title}</p>
          </div>
          <address class="not-italic text-sm leading-6 text-gray-600 sm:text-right">
            <div>{info.location} • {info.workFormat}</div>
            <a class="block underline-offset-4 hover:underline" href={`mailto:${info.contacts.email}`}>{info.contacts.email}</a>
            <a class="block underline-offset-4 hover:underline" href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}>{info.contacts.telegram}</a>
            <a class="block underline-offset-4 hover:underline" href={info.contacts.github}>{info.contacts.github.replace("https://", "")}</a>
          </address>
        </header>

        <section class="mb-8">
          <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">Summary</h2>
          <div class="space-y-3 text-sm leading-6 text-gray-700">
            {info.about.slice(0, 4).map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </section>

        <section class="mb-8">
          <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">Skills</h2>
          <ul class="list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
            {skillGroups.map(([title, skills]) => (
              <li>
                <span class="font-semibold text-black">{title}:</span> {skills.join(", ")}
              </li>
            ))}
          </ul>
        </section>

        <section class="mb-8">
          <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">Work Experience</h2>
          <div class="space-y-6">
            {info.experience.map((job) => (
              <section>
                <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                  <p class="text-lg font-bold">{job.position} | {job.company}</p>
                  <p class="text-sm text-gray-600">{job.period}</p>
                </div>
                <p class="mt-2 text-sm font-semibold leading-6 text-gray-700">{job.summary}</p>
                <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
                  {job.details.map((detail) => (
                    <li>{detail}</li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </section>

        <section>
          <h2 class="mb-4 border-b border-gray-300 pb-2 text-2xl font-semibold">Focus</h2>
          <ul class="list-disc space-y-1 pl-5 text-sm leading-6 text-gray-700">
            {info.about.slice(4).map((paragraph) => (
              <li>{paragraph}</li>
            ))}
          </ul>
        </section>
      </article>
    </main>
  )}

  {style.id === "engen" && (
    <main class="min-h-screen bg-zinc-100 px-4 py-4 font-sans text-black print:min-h-0 print:bg-white print:px-0 print:py-0 print:text-[10pt]">
      <article class="mx-auto max-w-[55rem] bg-white px-3 py-4 shadow-sm print:max-w-none print:p-0 print:shadow-none">
        <header class="flex flex-col gap-3 p-2 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between print:gap-1 print:p-0">
          <h1 class="text-3xl font-black leading-tight print:text-2xl">
            {info.name}
            <span class="block text-lg font-light text-zinc-700 print:text-base">
              {info.title}
            </span>
          </h1>

          <address class="text-sm not-italic leading-relaxed text-zinc-700 sm:text-right print:text-[9pt] print:leading-snug">
            <span class="block">{info.location} • {info.workFormat}</span>
            <a class="block whitespace-nowrap underline-offset-4 hover:underline" href={`mailto:${info.contacts.email}`}>
              {info.contacts.email}
            </a>
            <a class="block whitespace-nowrap underline-offset-4 hover:underline" href={`https://t.me/${info.contacts.telegram.replace("@", "")}`}>
              {info.contacts.telegram}
            </a>
            <a class="block whitespace-nowrap underline-offset-4 hover:underline" href={info.contacts.github}>
              {info.contacts.github.replace("https://", "")}
            </a>
          </address>
        </header>

        <div class="grid gap-y-3 [grid-template-columns:max-content_1fr] print:gap-y-2">
          <section class="col-span-2 grid grid-cols-1 gap-x-4 gap-y-3 border-t-2 border-indigo-900 px-2 pt-3 leading-relaxed sm:[grid-template-columns:subgrid] print:px-0 print:pt-2 print:leading-snug">
            <h2 class="text-center text-lg font-light uppercase leading-none text-zinc-800 sm:text-left print:text-[11pt]">
              Summary
            </h2>
            <div class="space-y-3 text-sm leading-6 text-zinc-800 sm:col-start-2 print:space-y-2 print:text-[10pt] print:leading-snug">
              {info.about.slice(0, 3).map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </section>

          <section class="col-span-2 grid grid-cols-1 gap-x-4 gap-y-3 border-t-2 border-indigo-900 px-2 pt-3 leading-relaxed sm:[grid-template-columns:subgrid] print:px-0 print:pt-2 print:leading-snug">
            <h2 class="text-center text-lg font-light uppercase leading-none text-zinc-800 sm:text-left print:text-[11pt]">
              Skills
            </h2>
            <div class="grid gap-2 text-sm leading-6 text-zinc-800 sm:col-start-2 print:gap-1 print:text-[10pt] print:leading-snug">
              {skillGroups.map(([title, skills]) => (
                <p>
                  <span class="font-bold">{title}:</span> {skills.join(", ")}
                </p>
              ))}
            </div>
          </section>

          <section class="col-span-2 grid grid-cols-1 gap-x-4 gap-y-3 border-t-2 border-indigo-900 px-2 pt-3 leading-relaxed sm:[grid-template-columns:subgrid] print:px-0 print:pt-2 print:leading-snug">
            <h2 class="text-center text-lg font-light uppercase leading-none text-zinc-800 sm:text-left print:text-[11pt]">
              Experience
            </h2>
            <div class="space-y-5 sm:col-start-2 print:space-y-3">
              {info.experience.map((job) => (
                <section class="break-inside-avoid">
                  <header class="grid gap-x-2 sm:grid-cols-[max-content_1fr]">
                    <h3 class="text-base font-black leading-snug print:text-[10pt]">
                      {job.position}
                    </h3>
                    <span class="text-sm font-light leading-snug sm:col-start-1 print:text-[9pt]">
                      {job.company}
                    </span>
                    <span class="text-sm font-light leading-snug text-zinc-700 sm:col-start-2 sm:row-start-1 sm:justify-self-end print:text-[9pt]">
                      {job.period}
                    </span>
                  </header>

                  <p class="mt-2 text-sm font-semibold leading-6 text-zinc-800 print:mt-1 print:text-[10pt] print:leading-snug">
                    {job.summary}
                  </p>
                  <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-6 text-zinc-800 print:mt-1 print:space-y-0.5 print:pl-4 print:text-[10pt] print:leading-snug">
                    {job.details.map((detail) => (
                      <li class="pl-1">{detail}</li>
                    ))}
                  </ul>
                </section>
              ))}
            </div>
          </section>

          <section class="col-span-2 grid grid-cols-1 gap-x-4 gap-y-3 border-t-2 border-indigo-900 px-2 pt-3 leading-relaxed sm:[grid-template-columns:subgrid] print:px-0 print:pt-2 print:leading-snug">
            <h2 class="text-center text-lg font-light uppercase leading-none text-zinc-800 sm:text-left print:text-[11pt]">
              Focus
            </h2>
            <ul class="list-disc space-y-1 pl-5 text-sm leading-6 text-zinc-800 sm:col-start-2 print:space-y-0.5 print:pl-4 print:text-[10pt] print:leading-snug">
              {info.about.slice(3).map((paragraph) => (
                <li class="pl-1">{paragraph}</li>
              ))}
            </ul>
          </section>
        </div>
      </article>
    </main>
  )}
