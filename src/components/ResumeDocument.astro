---
import type { ResumeStyleId } from "../data/resumeStyles";
import ClassicTemplate from "./resume-templates/ClassicTemplate.astro";
import CompactTemplate from "./resume-templates/CompactTemplate.astro";
import DefaultTemplate from "./resume-templates/DefaultTemplate.astro";
import EditorialTemplate from "./resume-templates/EditorialTemplate.astro";
import EngenTemplate from "./resume-templates/EngenTemplate.astro";
import MinimalMonoTemplate from "./resume-templates/MinimalMonoTemplate.astro";

const { style } = Astro.props;

const templates = {
  classic: ClassicTemplate,
  compact: CompactTemplate,
  editorial: EditorialTemplate,
  default: DefaultTemplate,
  engen: EngenTemplate,
  "minimal-mono": MinimalMonoTemplate,
} satisfies Record<ResumeStyleId, unknown>;

const Template = templates[style.id as ResumeStyleId];
---

<Template />
