---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Gorushkin Artyom",
  description = "Senior Frontend Developer CV",
} = Astro.props;
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-100 text-zinc-950 antialiased print:bg-white">
    <slot />
  </body>
</html>
