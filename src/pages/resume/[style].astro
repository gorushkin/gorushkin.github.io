---
import Layout from "../../layouts/Layout.astro";
import ResumeDocument from "../../components/ResumeDocument.astro";
import { documentTitle } from "../../components/resumeData";
import { resumeStyles } from "../../data/resumeStyles";

export function getStaticPaths() {
  if (import.meta.env.SINGLE_RESUME_BUILD === "true") {
    return [];
  }

  const targetStyle = import.meta.env.RESUME_STYLE;
  const styles = targetStyle
    ? resumeStyles.filter((style) => style.id === targetStyle)
    : resumeStyles;

  return styles.map((style) => ({
    params: { style: style.id },
    props: { style },
  }));
}

const { style } = Astro.props;
---

<Layout title={documentTitle}>
  <div class="print:contents">
    <div class="fixed right-4 top-4 z-10 print:hidden">
      <button
        class="inline-flex items-center bg-zinc-950 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-zinc-800"
        type="button"
        data-download-resume
      >
        Скачать PDF
      </button>
    </div>

    <ResumeDocument style={style} />
  </div>

  <script>
    document
      .querySelector("[data-download-resume]")
      ?.addEventListener("click", () => {
        window.print();
      });
  </script>
</Layout>
